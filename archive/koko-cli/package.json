{
  "name": "@koko/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "koko-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/index.js start\"",
    "start": "node dist/index.js start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@koko/openclaw-client": "workspace:*",
    "@koko/protocol": "workspace:*",
    "pino": "^9.14.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@koko/relay": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/qrcode-terminal": "^0.12.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
