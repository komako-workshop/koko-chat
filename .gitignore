# reference image piles, and run logs. Final selected brand assets live under
# `apps/koko-chat/assets/brand/` and ARE committed.
.brand/out/
.brand/out_v2/
.brand/out_v3/
.brand/refs/
.brand/refs2/
.brand/refs3/
.brand/refs_user/
.brand/run.log
.brand/*.jsonl
.brand/preview-result.png
.brand/shot-*.png
.brand/deeply-avatar-lab/out/

# Misc dev artifacts (screenshots / event dumps captured during iterations).
# These get cycled often; keep code-side debug tooling under scripts/ instead.
/_shot.png
/preview.png
/app.json
tmp-debug/
tmp-shots/

